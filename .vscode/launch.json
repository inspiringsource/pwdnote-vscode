{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension on pwdnote-vscode",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--reuse-window",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ]
    }
  ]
}